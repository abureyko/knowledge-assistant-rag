# Offline mode works without external LLM calls.
# Configure private provider credentials only when live generation is required.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=offline-rule-based

# OpenAI-compatible provider example:
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=Qwen/Qwen3-Coder-Next-FP8
#
# Optional Cloud.ru Foundation Models example:
# LLM_BASE_URL=https://foundation-models.api.cloud.ru/v1
# LLM_MODEL=t-tech/T-lite-it-2.1
#
# Optional personal keys can use any OpenAI-compatible provider:
# OpenRouter: https://openrouter.ai/api/v1
# Groq: https://api.groq.com/openai/v1
EMBEDDING_MODEL=hash://v1
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_agent_docs
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=knowledge-agent-core
GRAPH_MODE=core
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=80
